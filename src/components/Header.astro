---
const links = [
  { href: '#about', label: 'About' },
  { href: '#work', label: 'Work' },
  { href: '#projects', label: 'Projects' },
  { href: '#contact', label: 'Contact' },
];
---

<header class="fixed top-0 left-0 right-0 z-50 bg-gray-50/90 backdrop-blur-md border-b border-black/5">
  <nav class="max-w-4xl mx-auto px-8 py-4 flex items-center justify-between">
    <a href="/" class="text-2xl font-bold text-brand tracking-tight">JP</a>
    <ul class="flex gap-8">
      {links.map((link) => (
        <li>
          <a
            href={link.href}
            class="text-sm font-medium text-gray-500 hover:text-brand transition-colors duration-200"
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</header>
