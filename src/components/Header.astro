---
const links = [
  { href: '#about', label: 'About' },
  { href: '#work', label: 'Work' },
  { href: '#projects', label: 'Projects' },
  { href: '#contact', label: 'Contact' },
];
---

<header class="fixed top-0 left-0 right-0 z-50 bg-gray-50/90 dark:bg-gray-900/90 backdrop-blur-md border-b border-black/5 dark:border-white/10">
  <nav class="max-w-4xl mx-auto px-8 py-4 flex items-center justify-between">
    <a href="/" class="inline-flex items-center" aria-label="Julian Pinzer home">
      <span
        class="block h-9 w-9 bg-brand dark:bg-brand-light transition-colors duration-200"
        style="-webkit-mask: url('/icon.png') center / contain no-repeat; mask: url('/icon.png') center / contain no-repeat;"
      ></span>
      <span class="sr-only">Julian Pinzer</span>
    </a>
    <div class="flex items-center gap-6">
      <ul class="flex gap-8">
        {links.map((link) => (
          <li>
            <a
              href={link.href}
              class="text-sm font-medium text-gray-500 dark:text-gray-400 hover:text-brand dark:hover:text-brand transition-colors duration-200"
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>
      <button
        id="theme-toggle"
        aria-label="Toggle dark mode"
        class="p-2 rounded-md text-gray-500 dark:text-gray-400 hover:text-brand dark:hover:text-brand hover:bg-gray-100 dark:hover:bg-gray-800 transition-all duration-200"
      >
        <!-- Sun icon (shown in dark mode) -->
        <svg id="icon-sun" xmlns="http://www.w3.org/2000/svg" class="hidden w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m8.66-9h-1M4.34 12h-1m15.07-6.07-.71.71M6.34 17.66l-.71.71m12.02 0-.71-.71M6.34 6.34l-.71-.71M12 7a5 5 0 1 0 0 10A5 5 0 0 0 12 7z" />
        </svg>
        <!-- Moon icon (shown in light mode) -->
        <svg id="icon-moon" xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
        </svg>
      </button>
    </div>
  </nav>
</header>

<script is:inline>
  function updateIcons() {
    const isDark = document.documentElement.classList.contains('dark');
    document.getElementById('icon-sun').classList.toggle('hidden', !isDark);
    document.getElementById('icon-moon').classList.toggle('hidden', isDark);
  }

  updateIcons();

  document.getElementById('theme-toggle').addEventListener('click', () => {
    const isDark = document.documentElement.classList.toggle('dark');
    localStorage.setItem('theme', isDark ? 'dark' : 'light');
    updateIcons();
  });
</script>
