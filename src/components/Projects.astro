---
const featured = {
  title: 'CardMystic',
  href: 'https://cardmystic.com',
  description: 'An AI-powered Magic: The Gathering card search engine. Find cards using natural language queries instead of exact keywords — just describe what you\'re looking for and let the AI handle the rest.',
  tags: ['Nuxt / Vue', 'AI Search', 'Open Source'],
};

const projects = [
  {
    title: 'Circle Game',
    href: 'https://circlega.me',
    description: 'An Augmented-Reality Game that uses your device\'s camera to track your index finger in mid-air. Draw a circle in the air and get scored on how close it is to a perfect circle!',
    tags: ['Open Source', 'Game', 'Vibe-Coded'],
  },
  {
    title: 'dependabot-core',
    href: 'https://github.com/dependabot/dependabot-core/commits/main/?author=jpinz',
    description: 'Dependabot\'s core logic for creating update PRs.',
    tags: ['Open Source'],
  }
];
---

<section id="projects" class="py-24">
  <div class="max-w-4xl mx-auto px-8">
    <h2 class="text-3xl font-bold mb-10 text-gray-900 dark:text-white">
      Projects
      <span class="block w-12 h-0.5 bg-brand mt-2 rounded-full"></span>
    </h2>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
      <!-- Featured Project -->
      <a
        href={featured.href}
        target="_blank"
        rel="noopener noreferrer"
        class="col-span-full p-8 rounded-lg border border-brand bg-gradient-to-br from-brand-light to-white dark:from-gray-800 dark:to-gray-900 hover:-translate-y-1 hover:shadow-xl hover:shadow-black/5 transition-all duration-200 block"
      >
        <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-2">{featured.title}</h3>
        <p class="text-sm text-gray-600 dark:text-gray-300 mb-4 leading-relaxed">{featured.description}</p>
        <div class="flex flex-wrap gap-2">
          {featured.tags.map((tag) => (
            <span class="text-xs font-medium text-brand bg-brand/10 px-3 py-1 rounded-full">{tag}</span>
          ))}
        </div>
      </a>

      <!-- Other Projects -->
      {projects.map((project) => (
        <a
          href={project.href}
          target="_blank"
          rel="noopener noreferrer"
          class="p-6 rounded-lg border border-gray-100 dark:border-gray-700 bg-white dark:bg-gray-800 hover:-translate-y-1 hover:border-brand dark:hover:border-brand hover:shadow-lg hover:shadow-black/5 transition-all duration-200 block"
        >
          <h3 class="text-base font-semibold text-gray-900 dark:text-white mb-2">{project.title}</h3>
          <p class="text-sm text-gray-500 dark:text-gray-400 mb-4">{project.description}</p>
          <div class="flex flex-wrap gap-2">
            {project.tags.map((tag) => (
              <span class="text-xs font-medium text-brand bg-brand/10 px-3 py-1 rounded-full">{tag}</span>
            ))}
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
